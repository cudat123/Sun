{
  "name": "taixiu-analyzer",
  "version": "2.0.0",
  "description": "Tool phân tích và dự đoán Tài Xỉu với 84 models thông minh",
  "main": "apisun.js",
  "scripts": {
    "start": "node apisun.js",
    "dev": "nodemon apisun.js",
